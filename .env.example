# Required — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your_random_secret_key_here

# Required — your Google Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — set to 1 when running behind HTTPS (e.g. AWS with SSL)
# HTTPS=1

# ── The following are NOT needed on the server ──
# Users enter their own email credentials via the login screen.
# These are only here as examples / for local CLI testing (chat.py).
# EMAIL_ADDRESS=your.email@gmail.com
# EMAIL_PASSWORD=your_16_char_app_password_here
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
